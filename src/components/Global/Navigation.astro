---
import Icon from "@components/UI/Icon.astro";
import ThemeIcon from "@components/UI/ThemeIcon.astro";

// Navigation items
const navItems = [
  { text: "Item1", href: "#" },
  { text: "Item2", href: "#" },
  { text: "Item3", href: "#" },
];

// Get the current URL path to highlight the active link
const currentPath = Astro.url.pathname;
---

<!-- Desktop Navigation -->
<nav class="hidden lg:block">
  <ul class="flex items-center space-x-6">
    {
      navItems.map((item) => {
        // Determine if a link is active based on exact match or sub-path matching,
        // excluding the root path from prefix matching to avoid false positives.
        const isActive =
          currentPath === item.href ||
          (item.href !== "/" && currentPath.startsWith(item.href));

        return (
          <li>
            <a
              href={item.href}
              class={`text-base font-medium transition-colors hover:text-primary-600 ${
                isActive ? "text-primary-600" : ""
              }`}
              aria-current={isActive ? "page" : undefined}
              style="color: var(--text);"
            >
              {item.text}
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>

<div class="flex items-center gap-2">
  <!-- Theme toggle is always visible -->
  <ThemeIcon />
  <!-- Mobile Menu Button -->
  <button
    id="mobile-menu-button"
    class="lg:hidden p-2 transition-colors relative"
    style="color: var(--text);"
    aria-label="Toggle Menu"
    aria-expanded="false"
  >
    <span id="icon-wrapper" class="relative block h-6 w-6">
      <Icon
        id="icon-menu"
        name="menu"
        class="h-6 w-6 absolute inset-0 transition-all duration-300 ease-in-out opacity-100 rotate-0"
      />
      <Icon
        id="icon-close"
        name="close"
        class="h-6 w-6 absolute inset-0 transition-all duration-300 ease-in-out opacity-0 -rotate-90"
      />
    </span>
  </button>
</div>

<!-- Mobile Menu Dropdown - Compact & Clean -->
<div
  id="mobile-menu"
  class="absolute top-full left-0 right-0 h-dvh shadow-lg border-t lg:hidden z-50"
  style="background-color: var(--surface); border-color: var(--card-border);"
  role="menu"
  aria-labelledby="mobile-menu-button"
>
  <!-- Navigation Links in Grid -->
  <div class="px-4 py-16">
    <div class="grid grid-cols-2 gap-3">
      {
        navItems.map((item) => {
          const isActive =
            currentPath === item.href ||
            (item.href !== "/" && currentPath.startsWith(item.href));

          return (
            <a
              href={item.href}
              class={`block px-4 py-3 text-sm font-medium rounded-lg transition-colors text-center border ${
                isActive ? "active-link" : ""
              }`}
              style={`
    color: ${isActive ? "var(--primary)" : "var(--text)"};
    border-color: ${isActive ? "var(--primary-border)" : "transparent"};
  `}
              role="menuitem"
              aria-current={isActive ? "page" : undefined}
            >
              {item.text}
            </a>
          );
        })
      }
    </div>
  </div>
</div>

<style>
  /* Mobile menu button animation */
  #mobile-menu-button:hover svg {
    transform: scale(1.1);
  }

  #mobile-menu-button svg {
    transition: transform 0.2s ease;
  }

  /* Slide down suave */
  #mobile-menu {
    transform-origin: top;
    transition:
      transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    transform: scaleY(0);
    opacity: 0;
    pointer-events: none;
  }

  #mobile-menu.show {
    transform: scaleY(1);
    opacity: 1;
    pointer-events: auto;
  }

  /* Rotación del icono */
  #icon-menu {
    transition:
      opacity 0.25s ease,
      transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #icon-close {
    transition:
      opacity 0.25s ease,
      transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Active state styling */
  #mobile-menu a[aria-current="page"] {
    font-weight: 600;
  }

  /* Hover (only on non-active links) */
  #mobile-menu a:hover {
    background-color: var(--btn-secondary-hover);
  }

  /* Active */
  #mobile-menu a.active-link {
    background-color: var(--primary-soft);
  }
</style>

<script>
  // Mobile menu functionality
  document.addEventListener("DOMContentLoaded", () => {
    const mobileMenuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");
    const iconMenu = document.getElementById("icon-menu");
    const iconClose = document.getElementById("icon-close");

    if (!mobileMenuButton || !mobileMenu) return;

    let isMenuOpen = false;

    // Function to toggle mobile menu
    const toggleMobileMenu = () => {
      isMenuOpen = !isMenuOpen;

      if (isMenuOpen) {
        // Show menu
        mobileMenu.classList.add("show");
        mobileMenuButton.setAttribute("aria-expanded", "true");
        // Hamburguesa → desaparece girando
        iconMenu?.classList.replace("opacity-100", "opacity-0");
        iconMenu?.classList.replace("rotate-0", "rotate-90");
        // X → aparece girando
        iconClose?.classList.replace("opacity-0", "opacity-100");
        iconClose?.classList.replace("-rotate-90", "rotate-0");
      } else {
        // Hide menu
        mobileMenu.classList.remove("show");
        mobileMenuButton.setAttribute("aria-expanded", "false");
        // X → desaparece girando
        iconClose?.classList.replace("opacity-100", "opacity-0");
        iconClose?.classList.replace("rotate-0", "-rotate-90");
        // Hamburguesa → aparece girando
        iconMenu?.classList.replace("opacity-0", "opacity-100");
        iconMenu?.classList.replace("rotate-90", "rotate-0");
      }
    };

    // Event listeners
    mobileMenuButton?.addEventListener("click", (e) => {
      e.stopPropagation();
      toggleMobileMenu();
    });

    // Close menu when clicking outside
    document.addEventListener("click", (e) => {
      if (!(e.target instanceof Node)) return;

      const clickedThemeIcon = (e.target as Element).closest("#themeToggle");
      if (
        isMenuOpen &&
        !mobileMenu.contains(e.target) &&
        !mobileMenuButton.contains(e.target) &&
        !clickedThemeIcon
      ) {
        toggleMobileMenu();
      }
    });

    // Close menu when clicking a navigation link
    const navLinks = mobileMenu?.querySelectorAll('a[href^="/"]');
    navLinks?.forEach((link) => {
      link.addEventListener("click", () => {
        if (isMenuOpen) {
          setTimeout(() => toggleMobileMenu(), 100);
        }
      });
    });

    // Keyboard navigation
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isMenuOpen) {
        toggleMobileMenu();
      }
    });

    // Handle window resize
    window.addEventListener("resize", () => {
      if (window.innerWidth >= 1024 && isMenuOpen) {
        toggleMobileMenu();
      }
    });
  });
</script>

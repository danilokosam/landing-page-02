---
import Icon from "@components/UI/Icon.astro";
import ThemeIcon from "@components/UI/ThemeIcon.astro";
import LanguagePicker from "@components/UI/LanguagePicker.astro";
import { useTranslations, type Lang } from "@i18n/utils";

export interface Props {
  lang?: Lang;
}

const { lang = "es" } = Astro.props;
const t = useTranslations(lang);

// Navigation items
const navItems = [
  { text: t["nav.services"], href: "#services" },
  { text: t["nav.about"], href: "#about" },
  { text: t["nav.process"], href: "#process" },
  { text: t["nav.faq"], href: "#faq" },
];
---

<!-- Desktop Navigation -->
<nav class="hidden lg:block">
  <ul class="flex items-center space-x-6">
    {
      navItems.map((item) => {
        return (
          <li>
            <a
              href={item.href}
              class="nav-link text-base font-medium transition-all duration-200 relative"
              data-href={item.href}
            >
              {item.text}
            </a>
          </li>
        );
      })
    }
  </ul>
</nav>

<div class="flex items-center gap-2">
  <!-- Language picker -->
  <LanguagePicker lang={lang} />
  <!-- Theme toggle is always visible -->
  <ThemeIcon />
  <!-- Mobile Menu Button -->
  <button
    id="mobile-menu-button"
    class="lg:hidden p-2 transition-colors relative"
    style="color: var(--text);"
    aria-label="Toggle Menu"
    aria-expanded="false"
  >
    <span id="icon-wrapper" class="relative block h-6 w-6">
      <Icon
        id="icon-menu"
        name="menu"
        class="h-6 w-6 absolute inset-0 transition-all duration-300 ease-in-out opacity-100 rotate-0"
      />
      <Icon
        id="icon-close"
        name="close"
        class="h-6 w-6 absolute inset-0 transition-all duration-300 ease-in-out opacity-0 -rotate-90"
      />
    </span>
  </button>
</div>

<!-- Mobile Menu Dropdown - Compact & Clean -->
<div
  id="mobile-menu"
  class="absolute top-full left-0 right-0 h-dvh shadow-lg border-t lg:hidden z-50"
  style="background-color: var(--bg); border-color: var(--card-border);"
  role="menu"
  aria-labelledby="mobile-menu-button"
>
  <!-- Navigation Links in Grid -->
  <div class="px-4 py-16">
    <div class="grid grid-cols-2 gap-3">
      {
        navItems.map((item) => {
          return (
            <a
              href={item.href}
              class="mobile-nav-link block px-4 py-3 text-sm font-medium rounded-lg transition-all duration-200 text-center border"
              data-href={item.href}
            >
              {item.text}
            </a>
          );
        })
      }
    </div>
  </div>
</div>

<style>
  /* Mobile menu button animation */
  #mobile-menu-button:hover svg {
    transform: scale(1.1);
  }

  #mobile-menu-button svg {
    transition: transform 0.2s ease;
  }

  /* Slide down suave */
  #mobile-menu {
    transform-origin: top;
    transition:
      transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    transform: scaleY(0);
    opacity: 0;
    pointer-events: none;
  }

  #mobile-menu.show {
    transform: scaleY(1);
    opacity: 1;
    pointer-events: auto;
  }

  /* Rotación del icono */
  #icon-menu {
    transition:
      opacity 0.25s ease,
      transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #icon-close {
    transition:
      opacity 0.25s ease,
      transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Mobile nav active link styling */
  .mobile-nav-link.active {
    color: var(--primary);
    font-weight: 700;
    border-color: var(--ring);
    background-color: var(--primary-soft);
  }

  .mobile-nav-link:not(.active) {
    color: var(--text);
    border-color: transparent;
  }

  /* Hover effect for mobile links */
  .mobile-nav-link:hover {
    background-color: var(--btn-secondary-hover);
  }
</style>

<script>
  // Function to update active nav link styling
  const setActiveLink = (activeId: string) => {
    const navLinks = document.querySelectorAll(
      ".nav-link",
    ) as NodeListOf<HTMLAnchorElement>;
    const mobileNavLinks = document.querySelectorAll(
      ".mobile-nav-link",
    ) as NodeListOf<HTMLAnchorElement>;

    // Update desktop nav links
    navLinks.forEach((link) => {
      const href = link.getAttribute("data-href");
      const isActive = href === activeId;

      if (isActive) {
        link.setAttribute("aria-current", "page");
        link.style.color = "var(--primary)";
        link.style.fontWeight = "700";
        link.style.opacity = "1";
      } else {
        link.removeAttribute("aria-current");
        link.style.color = "var(--text)";
        link.style.fontWeight = "500";
        link.style.opacity = "0.85";
      }
    });

    // Update mobile nav links
    mobileNavLinks.forEach((link) => {
      const href = link.getAttribute("data-href");
      const isActive = href === activeId;

      if (isActive) {
        link.classList.add("active");
        link.setAttribute("aria-current", "page");
      } else {
        link.classList.remove("active");
        link.removeAttribute("aria-current");
      }
    });
  };

  // Intersection Observer to detect which section is in view
  const observeSections = () => {
    const sections = document.querySelectorAll(
      "[id='services'], [id='about'], [id='process'], [id='faq']",
    );

    const visibleSections = new Set<string>();

    const observerOptions = {
      root: null,
      rootMargin: "-80px 0px 0px 0px", // 80px arriba, igual a la altura del header sticky
      threshold: 0.1,
    };

    const observerCallback = (entries: IntersectionObserverEntry[]) => {
      entries.forEach((entry) => {
        const sectionId = entry.target.getAttribute("id");
        if (!sectionId) return;

        if (entry.isIntersecting) {
          visibleSections.add(sectionId);
          setActiveLink(`#${sectionId}`);
        } else {
          visibleSections.delete(sectionId);
          // If no section is visible, clear all active states
          if (visibleSections.size === 0) {
            setActiveLink("");
          }
        }
      });
    };

    const observer = new IntersectionObserver(
      observerCallback,
      observerOptions,
    );
    sections.forEach((section) => observer.observe(section));
  };

  // Add hover effects for desktop nav links
  const setupHoverEffects = () => {
    const navLinks = document.querySelectorAll(
      ".nav-link",
    ) as NodeListOf<HTMLAnchorElement>;
    navLinks.forEach((link) => {
      link.addEventListener("mouseover", function () {
        this.style.opacity = "1";
        this.style.textDecoration = "underline";
        this.style.textDecorationColor = "currentColor";
        this.style.textUnderlineOffset = "6px";
        this.style.textDecorationThickness = "2px";
      });

      link.addEventListener("mouseout", function () {
        this.style.textDecoration = "none";
        const isActive = this.getAttribute("aria-current") === "page";
        this.style.opacity = isActive ? "1" : "0.85";
      });
    });
  };

  // Initialize on DOM ready
  document.addEventListener("DOMContentLoaded", () => {
    observeSections();
    setupHoverEffects();
  });

  // Mobile menu functionality
  document.addEventListener("DOMContentLoaded", () => {
    const mobileMenuButton = document.getElementById("mobile-menu-button");
    const mobileMenu = document.getElementById("mobile-menu");
    const iconMenu = document.getElementById("icon-menu");
    const iconClose = document.getElementById("icon-close");

    if (!mobileMenuButton || !mobileMenu) return;

    let isMenuOpen = false;

    // Function to toggle mobile menu
    const toggleMobileMenu = () => {
      isMenuOpen = !isMenuOpen;

      if (isMenuOpen) {
        // Show menu
        mobileMenu.classList.add("show");
        mobileMenuButton.setAttribute("aria-expanded", "true");
        // Prevent background scrolling
        document.body.style.overflow = "hidden";
        // Hamburguesa → disappears as it spins
        iconMenu?.classList.replace("opacity-100", "opacity-0");
        iconMenu?.classList.replace("rotate-0", "rotate-90");
        // X → appears spinning
        iconClose?.classList.replace("opacity-0", "opacity-100");
        iconClose?.classList.replace("-rotate-90", "rotate-0");
      } else {
        // Hide menu
        mobileMenu.classList.remove("show");
        mobileMenuButton.setAttribute("aria-expanded", "false");
        // Restore background scrolling
        document.body.style.overflow = "";
        // X → disappears spinning
        iconClose?.classList.replace("opacity-100", "opacity-0");
        iconClose?.classList.replace("rotate-0", "-rotate-90");
        // Hamburguesa → appears spinning
        iconMenu?.classList.replace("opacity-0", "opacity-100");
        iconMenu?.classList.replace("rotate-90", "rotate-0");
      }
    };

    // Event listeners
    mobileMenuButton?.addEventListener("click", (e) => {
      e.stopPropagation();
      toggleMobileMenu();
    });

    // Close menu when clicking outside
    document.addEventListener("click", (e) => {
      if (!(e.target instanceof Node)) return;

      const clickedThemeIcon = (e.target as Element).closest("#themeToggle");
      if (
        isMenuOpen &&
        !mobileMenu.contains(e.target) &&
        !mobileMenuButton.contains(e.target) &&
        !clickedThemeIcon
      ) {
        toggleMobileMenu();
      }
    });

    // Close menu when clicking a navigation link
    const mobileLinks = mobileMenu?.querySelectorAll("a[data-href]");
    mobileLinks?.forEach((link) => {
      link.addEventListener("click", () => {
        if (isMenuOpen) {
          setTimeout(() => toggleMobileMenu(), 100);
        }
      });
    });

    // Keyboard navigation
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isMenuOpen) {
        toggleMobileMenu();
      }
    });

    // Handle window resize
    window.addEventListener("resize", () => {
      if (window.innerWidth >= 1024 && isMenuOpen) {
        toggleMobileMenu();
      }
    });
  });
</script>

---
import Navigation from "@components/Global/Navigation.astro";
import logoLight from "@assets/arka-1-light.svg";
import logoDark from "@assets/arka-1-dark.svg";
import type { Lang } from "@i18n/ui";

export interface Props {
  lang?: Lang;
}

const { lang = "es" } = Astro.props;
---

<header
  class="sticky top-0 z-50 w-full transition-all duration-300
         bg-[color-mix(in_srgb,var(--card-bg)_85%,transparent)]
         backdrop-blur-xl"
>
  <div
    class="mx-auto w-full max-w-7xl px-4 lg:px-0 flex items-center justify-between h-20"
  >
    <!-- Logo -->
    <a
      href="/"
      class="flex items-center gap-2 text-xl md:text-2xl font-semibold tracking-tight transition-opacity hover:opacity-80"
      style="color: var(--text);"
    >
      <span class="sr-only">arca</span>
      <span class="inline-flex items-center justify-center w-16 h-16">
        <img
          src={logoDark.src}
          alt="arca Logo dark"
          class="hidden dark:inline w-16 h-16"
        />
        <img
          src={logoLight.src}
          alt="arca Logo light"
          class="inline dark:hidden w-16 h-16"
        />
      </span>
    </a>
    <Navigation lang={lang} />
  </div>

  <!-- Gradient border -->
  <div class="absolute bottom-0 inset-x-0 h-px">
    <div
      class="absolute inset-0 bg-linear-to-r from-transparent via-(--primary)/40 to-transparent"
    >
    </div>
    <div
      class="absolute inset-x-1/4 -bottom-px h-0.5 bg-linear-to-r from-transparent via-(--secondary)/60 to-transparent blur-sm"
    >
    </div>
  </div>
</header>

---
interface Props {
  name: string;
  class?: string;
  id?: string;
}

const { name, class: className, id } = Astro.props;

// We define which icons use fill instead of stroke
const isFillIcon = ["facebook", "twitter", "instagram"].includes(name);
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  id={id}
  class={className}
  fill={isFillIcon ? "currentColor" : "none"}
  viewBox="0 0 24 24"
  stroke={isFillIcon ? "none" : "currentColor"}
  stroke-width={isFillIcon ? "0" : "2"}
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
>
  {name === "menu" && <path d="M4 6h16M4 12h16M4 18h16" />}
  {name === "close" && <path d="M6 18L18 6M6 6l12 12" />}
  {name === "arrow-up" && <path d="M12 19V5M5 12l7-7 7 7" />}
  {/* Process icons */}
  {
    name === "shield-check" && (
      <>
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10" />
        <path d="m9 12 2 2 4-4" />
      </>
    )
  }
  {
    name === "map-pin" && (
      <>
        <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z" />
        <circle cx="12" cy="10" r="3" />
      </>
    )
  }
  {
    name === "trending-up" && (
      <>
        <path d="m12 14 4-4 4 4" />
        <path d="M3 3v18h18" />
        <path d="m12 10V4h8v6l-4 4-4-4Z" />
      </>
    )
  }
  {
    name === "rocket" && (
      <>
        <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z" />
        <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z" />
        <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0" />
        <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5" />
      </>
    )
  }
  {/* Social icons */}
  {
    name === "facebook" && (
      <path d="M7 10v4h3v7h4v-7h3l1 -4h-4v-2a1 1 0 0 1 1 -1h3v-4h-3a5 5 0 0 0 -5 5v2h-3" />
    )
  }
  {
    name === "instagram" && (
      <>
        <path d="M4 8a4 4 0 0 1 4 -4h8a4 4 0 0 1 4 4v8a4 4 0 0 1 -4 4h-8a4 4 0 0 1 -4 -4l0 -8" />
        <path d="M9 12a3 3 0 1 0 6 0a3 3 0 0 0 -6 0" />
        <path d="M16.5 7.5v.01" />
      </>
    )
  }
  {
    name === "twitter" && (
      <path d="M8.267 3a1 1 0 0 1 .73 .317l.076 .092l4.274 5.828l5.946 -5.944a1 1 0 0 1 1.497 1.32l-.083 .094l-6.163 6.162l6.262 8.54a1 1 0 0 1 -.697 1.585l-.109 .006h-4.267a1 1 0 0 1 -.73 -.317l-.076 -.092l-4.276 -5.829l-5.944 5.945a1 1 0 0 1 -1.497 -1.32l.083 -.094l6.161 -6.163l-6.26 -8.539a1 1 0 0 1 .697 -1.585l.109 -.006h4.267z" />
    )
  }
</svg>

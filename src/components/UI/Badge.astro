---
interface Props {
  text: string;
  className?: string;
}

const { text, className = "" } = Astro.props;
---

<div
  class:list={[
    "group relative mx-auto inline-flex items-center justify-center overflow-hidden rounded-full",
    "px-5 py-2 text-sm sm:px-6 sm:py-2.5 sm:text-base md:px-8 md:py-3",
    "font-semibold text-white",
    "bg-linear-to-r from-(--primary) to-(--secondary)",
    "shadow-md shadow-(--primary)/20",
    "transition-all duration-500 ease-out",
    "hover:shadow-lg hover:shadow-(--primary)/30",
    className,
  ]}
>
  <span
    class="absolute inset-0 rounded-full bg-linear-to-r from-(--secondary) to-(--primary) opacity-0 transition-opacity duration-500 group-hover:opacity-100"
  ></span>
  <span class="relative z-10">{text}</span>
</div>

---
import { languages, type Lang } from "@i18n/ui";
import { getAlternateLangUrl } from "@i18n/utils";

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

// Build alternate language links
const otherLangs = (Object.keys(languages) as Lang[]).filter((l) => l !== lang);

const links = otherLangs.map((l) => ({
  code: languages[l],
  label: l === "es" ? "Cambiar a Español" : "Switch to English",
  href: getAlternateLangUrl(Astro.url, l),
}));
---

<div class="lang-picker relative">
  {
    links.map((link) => (
      <a
        href={link.href}
        aria-label={link.label}
        class="lang-btn inline-flex items-center justify-center gap-1.5 rounded-lg border border-(--card-border) px-3 py-1.5 text-xs font-semibold transition-all duration-200 hover:border-(--primary) hover:text-(--primary)"
        style="color: var(--text);"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="10" />
          <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20" />
          <path d="M2 12h20" />
        </svg>
        {link.code}
      </a>
    ))
  }
</div>

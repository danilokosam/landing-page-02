---
import { useTranslations } from "@i18n/utils";
import type { Lang } from "@i18n/ui";

export interface Props {
  lang?: Lang;
}

const { lang = "es" } = Astro.props;
const t = useTranslations(lang);
---

<section class="mt-24 px-4 text-center">
  <h2
    class="text-xs font-bold tracking-[0.2em] hero-gradient uppercase opacity-90"
  >
    {t["sponsors.heading"]}
  </h2>

  <div
    class="mt-12 flex flex-wrap justify-center items-center gap-x-12 gap-y-10 opacity-60 grayscale hover:opacity-100 hover:grayscale-0 transition-all duration-500 ease-in-out"
  >
    <div class="flex items-center gap-2 group">
      <div
        class="w-8 h-8 rounded-full border-2 border-dashed border-muted/50 flex items-center justify-center"
      >
        <span class="text-[10px]">S1</span>
      </div>
      <span class="text-lg font-medium">Sponsor 1</span>
    </div>

    <div class="flex items-center gap-2 group">
      <div
        class="w-8 h-8 rounded-full border-2 border-dashed border-muted/50 flex items-center justify-center"
      >
        <span class="text-[10px]">S2</span>
      </div>
      <span class="text-lg font-medium">Sponsor 2</span>
    </div>

    <div class="flex items-center gap-2 group">
      <div
        class="w-8 h-8 rounded-full border-2 border-dashed border-muted/50 flex items-center justify-center"
      >
        <span class="text-[10px]">S3</span>
      </div>
      <span class="text-lg font-medium">Sponsor 3</span>
    </div>

    <div class="flex items-center gap-2 group">
      <div
        class="w-8 h-8 rounded-full border-2 border-dashed border-muted/50 flex items-center justify-center"
      >
        <span class="text-[10px]">S4</span>
      </div>
      <span class="text-lg font-medium">Sponsor 4</span>
    </div>

    <div class="flex items-center gap-2 group">
      <div
        class="w-8 h-8 rounded-full border-2 border-dashed border-muted/50 flex items-center justify-center"
      >
        <span class="text-[10px]">S5</span>
      </div>
      <span class="text-lg font-medium">Sponsor 5</span>
    </div>

    <div class="flex items-center gap-2 group">
      <div
        class="w-8 h-8 rounded-full border-2 border-dashed border-muted/50 flex items-center justify-center"
      >
        <span class="text-[10px]">S6</span>
      </div>
      <span class="text-lg font-medium">Sponsor 6</span>
    </div>
  </div>
</section>

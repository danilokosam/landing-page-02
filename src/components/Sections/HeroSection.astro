---
import { useTranslations } from "@i18n/utils";
import type { Lang } from "@i18n/ui";
import BgSection from "./BgSection.astro";

export interface Props {
	lang?: Lang;
}

const { lang = "es" } = Astro.props;
const t = useTranslations(lang);
---

<section class=" relative w-full px-4 overflow-hidden">
	<!-- Background blob -->
	<BgSection />
	<!-- Content -->
	<div
		class="relative z-10 flex min-h-[90vh] flex-col items-center justify-center px-1.5 py-20 text-center sm:px-8 md:py-24"
	>
		<h1
			class="mx-auto max-w-4xl text-5xl font-bold leading-tight tracking-tight text-(--text) sm:text-5xl md:text-7xl"
		>
			{t["hero.titleStart"]}
			<span class="hero-heading-accent">{t["hero.titleAccent"]}</span>
		</h1>

		<p
			class="mx-auto mt-5 max-w-xl text-base text-(--muted) px-4 sm:px-20 md:px-10 sm:mt-6 sm:max-w-2xl sm:text-lg md:text-xl"
		>
			{t["hero.subtitle"]}
		</p>

		<div
			class="mt-8 flex w-full flex-col items-center justify-center gap-3 sm:mt-10 sm:w-auto sm:flex-row sm:gap-4"
		>
			<a
				class="w-full rounded-lg bg-(--primary) px-8 py-4 text-center font-semibold text-white shadow-lg shadow-(--primary)/25 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-(--primary)/30 sm:w-auto"
				href="#project-form"
			>
				{t["hero.cta"]}
			</a>
		</div>

		<!-- Stats -->
		<div
			class="mt-12 grid w-full max-w-3xl grid-cols-2 gap-4 sm:mt-16 md:grid-cols-4 md:gap-0 md:divide-x md:divide-(--card-border)"
		>
			<div class="flex flex-col items-center py-2">
				<span class="text-4xl font-bold text-(--primary)">120+</span>
				<span class="mt-1 text-(--muted) text-sm">{t["hero.stat1Label"]}</span>
			</div>
			<div class="flex flex-col items-center py-2">
				<span class="text-4xl font-bold text-(--secondary)">97%</span>
				<span class="mt-1 text-sm text-(--muted)">{t["hero.stat2Label"]}</span>
			</div>
			<div class="flex flex-col items-center py-2">
				<span class="text-4xl font-bold text-(--accent-lime)">4.9</span>
				<span class="mt-1 text-(--muted) text-sm">{t["hero.stat3Label"]}</span>
			</div>
			<div class="flex flex-col items-center py-2">
				<span class="text-4xl font-bold text-(--text)">24/7</span>
				<span class="mt-1 text-(--muted) text-sm">{t["hero.stat4Label"]}</span>
			</div>
		</div>
	</div>
</section>

<style>

	.hero-heading-accent {
		background: linear-gradient(135deg, var(--primary), var(--secondary));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
</style>

---
import HeadingText from "@components/UI/HeadingText.astro";

interface Props {
  id?: string;
  formGuid: string;
}

const { id, formGuid } = Astro.props;
---

<section id={id} class="mt-24 scroll-mt-24">
  <div
    class="form-showcase relative overflow-hidden rounded-lg border border-(--card-border) bg-(--card-bg) px-6 py-8 shadow-[0_30px_80px_-40px_var(--primary)] backdrop-blur-xl sm:px-8 lg:px-10 lg:py-10"
  >
    <div class="form-orb form-orb-primary"></div>
    <div class="form-orb form-orb-secondary"></div>

    <div
      class="relative grid gap-8 lg:grid-cols-[0.95fr_1.05fr] lg:items-center"
    >
      <div class="max-w-xl">
        <div
          class="inline-flex items-center rounded-full border border-(--primary-border) bg-(--primary-soft) px-4 py-1 text-sm font-medium text-(--primary)"
        >
          Project inquiry
        </div>

        <HeadingText
          level={2}
          text="Tell us about your"
          textGradient="next idea"
          className="mt-5 max-w-lg text-3xl font-bold tracking-tight md:text-5xl"
        />

        <p class="mt-4 max-w-xl text-base leading-7 text-(--muted) md:text-lg">
          Share the basics and we will have a clear starting point for the
          conversation. This demo form is designed to preview the experience and
          includes simple client-side input validation.
        </p>

        <div class="mt-8 grid gap-4 sm:grid-cols-2">
          <div
            class="md:info-card rounded-lg md:border-2 border-(--card-border) md:p-4"
          >
            <p class="text-sm font-semibold text-(--text)">Fast contact</p>
            <p class="mt-2 text-sm leading-6 text-(--muted)">
              Leave your name and phone number so we can follow up with context.
            </p>
          </div>

          <div
            class="md:info-card rounded-lg md:border border-(--card-border) md:p-4"
          >
            <p class="text-sm font-semibold text-(--text)">Clear brief</p>
            <p class="mt-2 text-sm leading-6 text-(--muted)">
              A short project idea helps frame scope, goals and the right next
              step.
            </p>
          </div>
        </div>
      </div>

      <form
        id="contact-form"
        class="rounded-lg border border-(--card-border) bg-(--surface)/90 p-5 shadow-[0_24px_60px_-35px_rgba(15,23,42,0.55)] sm:p-7"
        novalidate
      >
        <!-- Hidden field required by the endpoint -->
        <input type="hidden" name="formGuid" value={formGuid} />

        <div class="grid gap-5">
          <div>
            <label
              class="mb-2 block text-sm font-medium text-(--text)"
              for="firstname"
            >
              Name
            </label>
            <input
              id="firstname"
              name="firstname"
              type="text"
              placeholder="Your full name"
              required
              minlength="1"
              maxlength="80"
              class="form-field w-full rounded-lg border border-(--card-border) bg-(--bg) px-4 py-3 text-base text-(--text) placeholder:text-(--muted)"
            />
            <p
              class="form-error mt-1.5 hidden text-sm text-red-500"
              data-field="firstname"
            >
            </p>
          </div>

          <div>
            <label
              class="mb-2 block text-sm font-medium text-(--text)"
              for="email"
            >
              Email
            </label>
            <input
              id="email"
              name="email"
              type="email"
              placeholder="you@example.com"
              required
              maxlength="254"
              class="form-field w-full rounded-lg border border-(--card-border) bg-(--bg) px-4 py-3 text-base text-(--text) placeholder:text-(--muted)"
            />
            <p
              class="form-error mt-1.5 hidden text-sm text-red-500"
              data-field="email"
            >
            </p>
          </div>

          <div>
            <label
              class="mb-2 block text-sm font-medium text-(--text)"
              for="phone"
            >
              Phone
            </label>
            <input
              id="phone"
              name="phone"
              type="tel"
              placeholder="+51 999 999 999"
              required
              minlength="7"
              maxlength="20"
              pattern="[0-9+()\-\s]{7,20}"
              inputmode="tel"
              class="form-field w-full rounded-lg border border-(--card-border) bg-(--bg) px-4 py-3 text-base text-(--text) placeholder:text-(--muted)"
            />
            <p
              class="form-error mt-1.5 hidden text-sm text-red-500"
              data-field="phone"
            >
            </p>
          </div>

          <div>
            <label
              class="mb-2 block text-sm font-medium text-(--text)"
              for="message"
            >
              Project idea
            </label>
            <textarea
              id="message"
              name="message"
              placeholder="Describe your project idea"
              required
              minlength="10"
              maxlength="500"
              rows="6"
              class="form-field min-h-36 w-full rounded-lg border border-(--card-border) bg-(--bg) px-4 py-3 text-base text-(--text) placeholder:text-(--muted)"
            ></textarea>
            <p
              class="form-error mt-1.5 hidden text-sm text-red-500"
              data-field="message"
            >
            </p>
          </div>

          <!-- Global feedback message -->
          <p id="form-feedback" class="hidden text-sm font-medium"></p>

          <div
            class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between"
          >
            <button
              id="submit-btn"
              type="submit"
              class="inline-flex items-center justify-center rounded-lg bg-(--primary) px-6 py-3.5 text-sm font-semibold text-white transition-transform duration-300 hover:-translate-y-1 disabled:cursor-not-allowed disabled:opacity-60"
            >
              Start Your Project
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>
</section>

<style>
  .form-showcase {
    background:
      radial-gradient(circle at top left, var(--primary-soft), transparent 32%),
      radial-gradient(
        circle at bottom right,
        color-mix(in srgb, var(--secondary) 18%, transparent),
        transparent 30%
      ),
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--surface) 84%, transparent),
        color-mix(in srgb, var(--bg-soft) 76%, transparent)
      );
  }

  .form-orb {
    position: absolute;
    border-radius: 9999px;
    filter: blur(18px);
    opacity: 0.5;
    pointer-events: none;
  }

  .form-orb-primary {
    top: -2rem;
    right: 12%;
    height: 9rem;
    width: 9rem;
    background: color-mix(in srgb, var(--primary) 28%, transparent);
  }

  .form-orb-secondary {
    bottom: -3rem;
    left: 8%;
    height: 11rem;
    width: 11rem;
    background: color-mix(in srgb, var(--secondary) 24%, transparent);
  }

  .info-card {
    background: color-mix(in srgb, var(--surface) 82%, transparent);
  }

  .form-field {
    transition:
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }

  .form-field:hover {
    border-color: var(--primary-border);
  }

  .form-field:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 4px var(--primary-soft);
    transform: translateY(-1px);
    outline: none;
  }

  .form-field.field-error {
    border-color: rgb(239 68 68);
    box-shadow: 0 0 0 4px rgb(239 68 68 / 0.12);
  }

  textarea.form-field {
    resize: vertical;
  }
</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement;
  const submitBtn = document.getElementById("submit-btn") as HTMLButtonElement;
  const feedback = document.getElementById(
    "form-feedback",
  ) as HTMLParagraphElement;

  function clearErrors() {
    form.querySelectorAll<HTMLParagraphElement>(".form-error").forEach((el) => {
      el.textContent = "";
      el.classList.add("hidden");
    });
    form
      .querySelectorAll<HTMLInputElement | HTMLTextAreaElement>(".form-field")
      .forEach((el) => {
        el.classList.remove("field-error");
      });
    feedback.textContent = "";
    feedback.className = "hidden text-sm font-medium";
  }

  function showFieldErrors(fieldErrors: Record<string, string[]>) {
    for (const [field, messages] of Object.entries(fieldErrors)) {
      const errorEl = form.querySelector<HTMLParagraphElement>(
        `[data-field="${field}"]`,
      );
      const inputEl = form.querySelector<
        HTMLInputElement | HTMLTextAreaElement
      >(`[name="${field}"]`);
      if (errorEl && messages.length > 0) {
        errorEl.textContent = messages[0];
        errorEl.classList.remove("hidden");
      }
      if (inputEl) {
        inputEl.classList.add("field-error");
      }
    }
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    clearErrors();

    submitBtn.disabled = true;
    submitBtn.textContent = "Sending...";

    try {
      const formData = new FormData(form);

      const res = await fetch("/api/hubspot/forms/submit", {
        method: "POST",
        body: formData,
      });

      const data = await res.json();

      if (!res.ok) {
        if (data.details) {
          showFieldErrors(data.details);
        } else {
          feedback.textContent =
            data.error || "Something went wrong. Please try again.";
          feedback.className = "text-sm font-medium text-red-500";
        }
        return;
      }

      // Success
      form.reset();
      feedback.textContent =
        data.inlineMessage ?? "Thank you! We'll be in touch soon.";
      feedback.className = "text-sm font-medium text-green-500";
    } catch {
      feedback.textContent =
        "Network error. Please check your connection and try again.";
      feedback.className = "text-sm font-medium text-red-500";
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "Start Your Project";
    }
  });
</script>

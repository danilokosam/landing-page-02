---
import { useTranslations } from "@i18n/utils";
import type { Lang } from "@i18n/ui";

export interface Props {
  id?: string;
  lang?: Lang;
}

const { id, lang = "es" } = Astro.props;
const t = useTranslations(lang);
---

<section id={id} class="mt-32 scroll-mt-20 autoShow">
  <div
    class="glass-card flex flex-col items-center gap-10 lg:flex-row md:items-start"
  >
    <!-- Image Placeholder -->
    <div class="rounded-lg w-full lg:max-w-md overflow-hidden group">
      <img
        class="w-full h-full rounded-lg object-cover"
        src="/img/about-image.webp"
        alt="about-image-arka"
      />
    </div>

    <div class="flex-1 space-y-10">
      <h2 class="text-4xl font-bold tracking-tight md:text-5xl">
        <span class="hero-gradient">{t["about.titleStart"]}</span> Arka
      </h2>

      <p class="section-muted text-lg leading-relaxed">
        {t["about.p1"]}
      </p>

      <p class="section-muted text-lg leading-relaxed">
        {t["about.p2"]}
      </p>

      <div class="grid grid-cols-2 gap-8 pt-6 md:grid-cols-4">
        <div class="space-y-1">
          <p class="text-3xl font-bold">01</p>
          <p class="section-muted text-sm">{t["about.value1"]}</p>
        </div>

        <div class="space-y-1">
          <p class="text-3xl font-bold">02</p>
          <p class="section-muted text-sm">{t["about.value2"]}</p>
        </div>

        <div class="space-y-1">
          <p class="text-3xl font-bold">03</p>
          <p class="section-muted text-sm">{t["about.value3"]}</p>
        </div>

        <div class="space-y-1">
          <p class="text-3xl font-bold">04</p>
          <p class="section-muted text-sm">{t["about.value4"]}</p>
        </div>
      </div>
    </div>
  </div>
</section>

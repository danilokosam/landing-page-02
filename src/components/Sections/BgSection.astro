<div class="bg-blob"></div>

<style is:inline>
	.bg-blob {
		width: 100%;
		height: 12rem;
		position: absolute;
		top: -1.5rem;
		left: 50%;
		transform: translateX(-50%);
		border-radius: 9999px;
		filter: blur(64px);
		background: linear-gradient(to left, var(--primary), var(--primary), var(--secondary));
		box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.25);
		animation:
			rotation 10s linear infinite,
			pulse 4s infinite both ease-in-out;
	}
	@keyframes pulse {
		0% {
			opacity: 0.2;
		}
		50% {
			opacity: 1;
		}
		100% {
			opacity: 0.2;
		}
	}

	@keyframes rotation {
		from {
			rotate: 0deg;
		}
		to {
			rotate: 360deg;
		}
	}
</style>

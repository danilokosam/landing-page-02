---
import HeadingText from "@components/UI/HeadingText.astro";
import TestimonialCard from "@components/UI/TestimonialCard.astro";

const testimonials = [
	{
		id: 1,
		text: "PrebuiltUI helped us move faster without sacrificing design quality. The components feel production-ready.",
		name: "Cristofer Levin",
		role: "Frontend engineer",
		image: "https://images.unsplash.com/photo-1633332755192-727a05c4013d?q=80&w=200",
	},
	{
		id: 2,
		text: "The attention to detail in PrebuiltUI is impressive. Saved me hours of repetitive work and time. Highly recommended.",
		name: "Rohan Mehta",
		role: "Startup founder",
		image: "https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?q=80&w=200",
	},
	{
		id: 3,
		text: "We were able ship faster using PrebuiltUI. The consistency across components made UI feel polished.",
		name: "Jason Kim",
		role: "Product designer",
		image: "https://images.unsplash.com/photo-1527980965255-d3b416303d12?w=200&auto=format&fit=crop&q=60",
	},
	{
		id: 4,
		text: "PrebuiltUI feels like it was built by people who actually ship products. Components are clean and easy to use.",
		name: "Alex Turner",
		role: "Full stack developer",
		image: "https://images.unsplash.com/photo-1522075469751-3a6694fb2f61?w=200&auto=format&fit=crop&q=60",
	},
	{
		id: 5,
		text: "PrebuiltUI helped us maintain design consistency across multiple projects. It's now a core part of design.",
		name: "Sofia Martinez",
		role: "UX designer",
		image: "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?q=80&w=100&h=100&auto=format&fit=crop",
	},
	{
		id: 6,
		text: "Our team productivity improved noticeably after adopting PrebuiltUI. It reduced design handoff friction.",
		name: "Daniel Wong",
		role: "UI designer",
		image: "https://raw.githubusercontent.com/prebuiltui/prebuiltui/main/assets/userImage/userImage1.png",
	},
];
---

<section class="">
	<div class="max-w-6xl mx-auto">
		<div class="text-center flex flex-col justify-center gap-4 mb-8">
			<div
				class="w-sm mx-auto mb-3 rounded-lg bg-(--primary) px-8 py-4 text-center font-semibold text-white shadow-lg shadow-(--primary)/25 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:shadow-(--primary)/30 "
			>
				<span class="">Loved by clients</span>
			</div>
			<HeadingText
				level={2}
				text="What people are"
				textGradient="saying"
				className="text-center text-3xl font-bold md:text-5xl tracking-tight"
			/>

			<p class="section-muted max-w-2xl mx-auto">
				Real feedback from founders, developers and teams building production-ready
				products.
			</p>
		</div>

		<div class="space-y-6">
			<!-- Fila 1: Scroll izquierda -->
			<div class="relative overflow-hidden">
				<div
					class="absolute left-0 top-0 bottom-0 w-28 gradient-left bg-linear-to-r from-(--bg) to-20% z-10 pointer-events-none"
				>
				</div>
				<div
					class="absolute right-0 top-0 bottom-0 w-28 gradient-right bg-linear-to-l from-(--bg) to-20% z-10 pointer-events-none"
				>
				</div>
				<div class="flex animate-scroll">
					<div class="flex gap-6 shrink-0 pr-6">
						{
							testimonials.slice(0, 3).map(
								(testimonial) => <TestimonialCard testimonial={testimonial} />,
							)
						}
					</div>
					<div class="flex gap-6 shrink-0 pr-6">
						{
							testimonials.slice(0, 3).map(
								(testimonial) => <TestimonialCard testimonial={testimonial} />,
							)
						}
					</div>
				</div>
			</div>

			<!-- Fila 2: Scroll derecha -->
			<div class="relative overflow-hidden">
				<div
					class="absolute left-0 top-0 bottom-0 w-28 bg-linear-to-r from-(--bg) to-20% gradient-left z-10 pointer-events-none"
				>
				</div>
				<div
					class="absolute right-0 top-0 bottom-0 w-28 gradient-right bg-linear-to-l from-(--bg) to-20% z-10 pointer-events-none"
				>
				</div>
				<div class="flex animate-scroll-reverse">
					<div class="flex gap-6 shrink-0 pr-6">
						{
							testimonials.slice(3, 6).map(
								(testimonial) => <TestimonialCard testimonial={testimonial} />,
							)
						}
					</div>
					<div class="flex gap-6 shrink-0 pr-6">
						{
							testimonials.slice(3, 6).map(
								(testimonial) => <TestimonialCard testimonial={testimonial} />,
							)
						}
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	@keyframes scroll {
		0% {
			transform: translateX(0);
		}
		100% {
			transform: translateX(-50%);
		}
	}

	@keyframes scrollReverse {
		0% {
			transform: translateX(-50%);
		}
		100% {
			transform: translateX(0);
		}
	}

	.animate-scroll {
		animation: scroll 30s linear infinite;
	}

	.animate-scroll-reverse {
		animation: scrollReverse 30s linear infinite;
	}

	/* Gradientes para fade edges
	.gradient-left {
		background: linear-gradient(to right, var(--bg-soft) 0%, transparent 100%);
	}

	.gradient-right {
		background: linear-gradient(to left, var(--bg-soft) 0%, transparent 100%);
	} */

	/* Estrellas */
	.star {
		color: transparent;
		background: linear-gradient(90deg, #ffd700 0%, #ffa500 100%);
		-webkit-background-clip: text;
		background-clip: text;
		fill: currentColor;
	}
</style>

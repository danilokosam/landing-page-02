---
import HeadingText from "@components/UI/HeadingText.astro";
import Badge from "@components/UI/Badge.astro";
import TestimonialCard from "@components/UI/TestimonialCard.astro";
import { useTranslations } from "@i18n/utils";
import type { Lang } from "@i18n/ui";

export interface Props {
  lang?: Lang;
}

const { lang = "es" } = Astro.props;
const t = useTranslations(lang);

const testimonials = [
  {
    id: 1,
    text: "Working with Arka was super easy. They understood exactly what we needed and helped us organize our site better. Now everything is much clearer for our clients.",
    name: "Cristofer Levin",
    role: "Communications Manager",
    image:
      "https://images.unsplash.com/photo-1633332755192-727a05c4013d?q=80&w=200",
  },
  {
    id: 2,
    text: "I really liked how close the Arka team felt. They always replied quickly and gave us ideas we hadn't even thought of. The final result exceeded our expectations.",
    name: "Rohan Mehta",
    role: "Digital Entrepreneur",
    image:
      "https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?q=80&w=200",
  },
  {
    id: 3,
    text: "The Arka team helped us simplify our website and now we get more inquiries than before. You can tell they care about details and user experience.",
    name: "Jason Kim",
    role: "Marketing Lead",
    image:
      "https://images.unsplash.com/photo-1527980965255-d3b416303d12?w=200&auto=format&fit=crop&q=60",
  },
  {
    id: 4,
    text: "Very professional and attentive. They explained every step and adapted the design to what we wanted. I recommend Arka if you want something personalized.",
    name: "Alex Turner",
    role: "Project Coordinator",
    image:
      "https://images.unsplash.com/photo-1522075469751-3a6694fb2f61?w=200&auto=format&fit=crop&q=60",
  },
  {
    id: 5,
    text: "Everything with Arka was transparent, from the quote to the delivery. The site works perfectly on mobile and loads super fast.",
    name: "Sofia Martinez",
    role: "Online Store Owner",
    image:
      "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?q=80&w=100&h=100&auto=format&fit=crop",
  },
  {
    id: 6,
    text: "Before, we didn't know how to show our services, but with Arka's help we now have a clear and easy-to-use website. Thanks for your patience and support!",
    name: "Daniel Wong",
    role: "Co-founder",
    image:
      "https://raw.githubusercontent.com/prebuiltui/prebuiltui/main/assets/userImage/userImage1.png",
  },
];
---

<section class="autoShow mt-24">
  <div class="max-w-6xl mx-auto">
    <div class="text-center flex flex-col justify-center gap-4 mb-8">
      <Badge text={t["testimonials.badge"]} />
      <HeadingText
        level={2}
        text={t["testimonials.headingStart"]}
        textGradient={t["testimonials.headingGradient"]}
        className="text-center text-3xl font-bold md:text-5xl tracking-tight"
      />

      <p class="section-muted max-w-2xl mx-auto">
        {t["testimonials.subtitle"]}
      </p>
    </div>

    <div class="space-y-6">
      <!-- Fila 1: Scroll izquierda -->
      <div class="relative overflow-hidden pb-4">
        <div
          class="absolute left-0 top-0 bottom-0 w-28 gradient-left bg-linear-to-r from-(--bg) to-20% z-10 pointer-events-none"
        >
        </div>
        <div
          class="absolute right-0 top-0 bottom-0 w-28 gradient-right bg-linear-to-l from-(--bg) to-20% z-10 pointer-events-none"
        >
        </div>
        <div class="flex carousel-track" data-carousel data-direction="left">
          <div class="flex gap-6 shrink-0 pr-6">
            {
              testimonials
                .slice(0, 3)
                .map((testimonial) => (
                  <TestimonialCard testimonial={testimonial} />
                ))
            }
          </div>
          <div class="flex gap-6 shrink-0 pr-6">
            {
              testimonials
                .slice(0, 3)
                .map((testimonial) => (
                  <TestimonialCard testimonial={testimonial} />
                ))
            }
          </div>
        </div>
      </div>

      <!-- Fila 2: Scroll derecha -->
      <div class="relative overflow-hidden pt-4">
        <div
          class="absolute left-0 top-0 bottom-0 w-28 bg-linear-to-r from-(--bg) to-20% gradient-left z-10 pointer-events-none"
        >
        </div>
        <div
          class="absolute right-0 top-0 bottom-0 w-28 gradient-right bg-linear-to-l from-(--bg) to-20% z-10 pointer-events-none"
        >
        </div>
        <div class="flex carousel-track" data-carousel data-direction="right">
          <div class="flex gap-6 shrink-0 pr-6">
            {
              testimonials
                .slice(3, 6)
                .map((testimonial) => (
                  <TestimonialCard testimonial={testimonial} />
                ))
            }
          </div>
          <div class="flex gap-6 shrink-0 pr-6">
            {
              testimonials
                .slice(3, 6)
                .map((testimonial) => (
                  <TestimonialCard testimonial={testimonial} />
                ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll("[data-carousel]").forEach((track) => {
      const firstGroup = track.children[0];
      const groupWidth = firstGroup.scrollWidth;
      const isRight = track.dataset.direction === "right";
      const speed = 0.3;
      let offset = isRight ? -groupWidth : 0;

      function animate() {
        if (isRight) {
          offset += speed;
          if (offset >= 0) offset = -groupWidth;
        } else {
          offset -= speed;
          if (Math.abs(offset) >= groupWidth) offset = 0;
        }

        track.style.transform = `translate3d(${offset}px, 0, 0)`;
        requestAnimationFrame(animate);
      }

      requestAnimationFrame(animate);
    });
  });
</script>

<style>
  .carousel-track {
    will-change: transform;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }

  /* Estrellas */
  .star {
    color: transparent;
    background: linear-gradient(90deg, #ffd700 0%, #ffa500 100%);
    -webkit-background-clip: text;
    background-clip: text;
    fill: currentColor;
  }
</style>

---
import HeadingText from "@components/UI/HeadingText.astro";
import Badge from "@components/UI/Badge.astro";
import TestimonialCard from "@components/UI/TestimonialCard.astro";
import { useTranslations } from "@i18n/utils";
import type { Lang } from "@i18n/ui";

export interface Props {
  lang?: Lang;
}

const { lang = "es" } = Astro.props;
const t = useTranslations(lang);

const testimonials = [
  {
    id: 1,
    text: "MarketingPlus redesigned our entire website and we saw a 40% increase in lead conversions within the first month. Their team truly understands what drives results.",
    name: "Cristofer Levin",
    role: "CEO at Vertex Solutions",
    image:
      "https://images.unsplash.com/photo-1633332755192-727a05c4013d?q=80&w=200",
  },
  {
    id: 2,
    text: "The brand strategy they built for us gave our startup a clear identity in a crowded market. Investors noticed the difference immediately.",
    name: "Rohan Mehta",
    role: "Founder of NovaTech",
    image:
      "https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?q=80&w=200",
  },
  {
    id: 3,
    text: "Working with MarketingPlus felt like having an in-house creative team. They delivered a website that perfectly captures our brand vision.",
    name: "Jason Kim",
    role: "Marketing Director at Bloom & Co.",
    image:
      "https://images.unsplash.com/photo-1527980965255-d3b416303d12?w=200&auto=format&fit=crop&q=60",
  },
  {
    id: 4,
    text: "Their growth marketing campaigns doubled our organic traffic in three months. Professional, data-driven, and always ahead of the curve.",
    name: "Alex Turner",
    role: "COO at Elevate Fitness",
    image:
      "https://images.unsplash.com/photo-1522075469751-3a6694fb2f61?w=200&auto=format&fit=crop&q=60",
  },
  {
    id: 5,
    text: "From concept to launch, MarketingPlus handled everything flawlessly. Our new site loads fast, looks stunning, and clients love the experience.",
    name: "Sofia Martinez",
    role: "Owner of Luna Interiors",
    image:
      "https://images.unsplash.com/photo-1438761681033-6461ffad8d80?q=80&w=100&h=100&auto=format&fit=crop",
  },
  {
    id: 6,
    text: "We struggled with online visibility for years until we partnered with MarketingPlus. Their paid media strategy brought us consistent, high-quality leads.",
    name: "Daniel Wong",
    role: "Managing Partner at Clearview Legal",
    image:
      "https://raw.githubusercontent.com/prebuiltui/prebuiltui/main/assets/userImage/userImage1.png",
  },
];
---

<section class="autoShow">
  <div class="max-w-6xl mx-auto">
    <div class="text-center flex flex-col justify-center gap-4 mb-8">
      <Badge text={t["testimonials.badge"]} />
      <HeadingText
        level={2}
        text={t["testimonials.headingStart"]}
        textGradient={t["testimonials.headingGradient"]}
        className="text-center text-3xl font-bold md:text-5xl tracking-tight"
      />

      <p class="section-muted max-w-2xl mx-auto">
        {t["testimonials.subtitle"]}
      </p>
    </div>

    <div class="space-y-6">
      <!-- Fila 1: Scroll izquierda -->
      <div class="relative overflow-hidden">
        <div
          class="absolute left-0 top-0 bottom-0 w-28 gradient-left bg-linear-to-r from-(--bg) to-20% z-10 pointer-events-none"
        >
        </div>
        <div
          class="absolute right-0 top-0 bottom-0 w-28 gradient-right bg-linear-to-l from-(--bg) to-20% z-10 pointer-events-none"
        >
        </div>
        <div class="flex carousel-track" data-carousel data-direction="left">
          <div class="flex gap-6 shrink-0 pr-6">
            {
              testimonials
                .slice(0, 3)
                .map((testimonial) => (
                  <TestimonialCard testimonial={testimonial} />
                ))
            }
          </div>
          <div class="flex gap-6 shrink-0 pr-6">
            {
              testimonials
                .slice(0, 3)
                .map((testimonial) => (
                  <TestimonialCard testimonial={testimonial} />
                ))
            }
          </div>
        </div>
      </div>

      <!-- Fila 2: Scroll derecha -->
      <div class="relative overflow-hidden">
        <div
          class="absolute left-0 top-0 bottom-0 w-28 bg-linear-to-r from-(--bg) to-20% gradient-left z-10 pointer-events-none"
        >
        </div>
        <div
          class="absolute right-0 top-0 bottom-0 w-28 gradient-right bg-linear-to-l from-(--bg) to-20% z-10 pointer-events-none"
        >
        </div>
        <div class="flex carousel-track" data-carousel data-direction="right">
          <div class="flex gap-6 shrink-0 pr-6">
            {
              testimonials
                .slice(3, 6)
                .map((testimonial) => (
                  <TestimonialCard testimonial={testimonial} />
                ))
            }
          </div>
          <div class="flex gap-6 shrink-0 pr-6">
            {
              testimonials
                .slice(3, 6)
                .map((testimonial) => (
                  <TestimonialCard testimonial={testimonial} />
                ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll("[data-carousel]").forEach((track) => {
      const firstGroup = track.children[0];
      const groupWidth = firstGroup.scrollWidth;
      const isRight = track.dataset.direction === "right";
      const speed = 0.3;
      let offset = isRight ? -groupWidth : 0;

      function animate() {
        if (isRight) {
          offset += speed;
          if (offset >= 0) offset = -groupWidth;
        } else {
          offset -= speed;
          if (Math.abs(offset) >= groupWidth) offset = 0;
        }

        track.style.transform = `translate3d(${offset}px, 0, 0)`;
        requestAnimationFrame(animate);
      }

      requestAnimationFrame(animate);
    });
  });
</script>

<style>
  .carousel-track {
    will-change: transform;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }

  /* Estrellas */
  .star {
    color: transparent;
    background: linear-gradient(90deg, #ffd700 0%, #ffa500 100%);
    -webkit-background-clip: text;
    background-clip: text;
    fill: currentColor;
  }
</style>
